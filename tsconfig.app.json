{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* Projects */
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    /* Emit */
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./node_modules/.tmp/tsc-app"
  },
  "include": ["app/**/*.ts", "app/**/*.tsx"],
  "exclude": ["**/*.spec.ts", "**/*.spec.tsx"]
}
