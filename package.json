{
  "name": "lazy_days_playground",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite-node --watch ./app/server/server.ts",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0 --rule \"no-console: ['error', { allow: ['error', 'info', 'warn'] }]\"",
    "lint:fix": "pnpm lint --fix",
    "test": "set DEBUG_TEST_POLLUTION=0&&vitest run",
    "test:cov": "set DEBUG_TEST_POLLUTION=0&& vitest run --coverage",
    "test:cov:debug": "set DEBUG_TEST_POLLUTION=1&& vitest run --coverage --reporter=verbose",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@fastify/error": "4.2.0",
    "axios": "1.16.1",
    "close-with-grace": "2.5.0",
    "dayjs": "1.11.20",
    "fastify": "5.8.5",
    "lodash-es": "4.18.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "6.9.1",
    "@types/eslint-plugin-security": "3.0.1",
    "@types/lodash-es": "4.17.12",
    "@types/node": "^25",
    "@typescript-eslint/parser": "8.59.4",
    "@vitest/coverage-v8": "4.1.6",
    "@vitest/spy": "4.1.6",
    "eslint": "9.39.4",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "globals": "17.6.0",
    "happy-dom": "20.9.0",
    "jiti": "2.7.0",
    "pino-pretty": "13.1.3",
    "type-fest": "5.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.13",
    "vite-node": "6.0.0",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "pnpm@11.1.2"
}
