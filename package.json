{
  "name": "lazy_days_playground",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm typegen && pnpm build:react && pnpm build:server",
    "build:clean": "rm -rf node_modules && pnpm store prune && rm -rf .react-router && rm -rf coverage && rm -rf dist && rm pnpm-lock.yaml && pnpm i && pnpm test:cov && pnpm typegen && pnpm lint && pnpm typecheck:no-typegen && pnpm build:no-typegen",
    "build:react": "react-router build",
    "build:server": "tsc --project tsconfig.server.json",
    "build:no-typegen": "pnpm build:react && pnpm build:server",
    "bump": "pnpm bump:deps && pnpm bump:overrides",
    "bump:deps": "ncu -u",
    "bump:overrides": "node ./.pnpm/scripts/update-overrides.script.ts",
    "dev": "node --env-file=.env.local.dev ./app/server/index.ts",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0 --rule \"no-console: ['error', { allow: ['error', 'info', 'warn'] }]\" --rule \"react-hooks/exhaustive-deps: off\"",
    "lint:fix": "pnpm lint --fix",
    "obsolete": "knip",
    "start": "node --env-file=.env.local.prod ./dist/fastify/server/index.js",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "pnpm typegen && tsc --noEmit",
    "typecheck:no-typegen": "tsc --noEmit",
    "typegen": "pnpm typegen:client && pnpm typegen:server && pnpm typegen:db",
    "typegen:db": "node --env-file=.env.local.dev node_modules/@gel/generate/dist/cli.js interfaces --file app/shared/types/generated/db/database.type.ts",
    "typegen:client": "react-router typegen",
    "typegen:server": "VITE_APP_TYPE_GENERATOR_MODE=type_generator node --env-file=.env.local.dev ./app/server/index.ts"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/csrf-protection": "7.1.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "9.1.3",
    "@hookform/resolvers": "5.2.2",
    "@iconify/react": "6.0.2",
    "@react-router/node": "7.15.0",
    "@react-router/serve": "7.15.0",
