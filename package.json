    "argon2": "0.44.0",
    "axios": "1.16.0",
    "classnames": "2.5.1",
    "dayjs": "1.11.20",
    "fastify": "5.8.5",
    "fastify-zod-openapi": "5.6.1",
    "gel": "2.2.0",
