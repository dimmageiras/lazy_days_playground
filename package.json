{
  "name": "lazy_days_playground",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node --env-file=.env.local.prod -e \"process.exit(0)\" && pnpm typegen && pnpm build:react && pnpm build:server",
    "build:react": "react-router build",
    "build:server": "tsc --project tsconfig.server.json",
    "check": "run-p -c \"check:type\" \"lint\"",
    "check:type": "run-p \"build:server --noEmit\" \"tsc --noEmit\"",
    "dev": "node --env-file=.env.local.dev ./server/index.ts",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0 --rule \"no-console: ['error', { allow: ['error', 'info', 'warn'] }]\" --rule \"react-hooks/exhaustive-deps: off\"",
    "lint:fix": "pnpm lint --fix",
    "start": "node --env-file=.env.local.prod ./dist/fastify/server/index.js",
    "typecheck": "pnpm typegen && tsc --noEmit",
    "typegen": "react-router typegen"
  },
  "dependencies": {
    "@fastify/static": "8.1.1",
    "@fastify/swagger": "9.6.1",
    "@fastify/swagger-ui": "5.2.3",
    "@mcansh/remix-fastify": "4.1.2",
    "@react-router/node": "7.10.1",
    "@react-router/serve": "7.10.1",
    "@tanstack/react-query": "5.90.12",
    "axios": "1.13.2",
    "classnames": "2.5.1",
    "dayjs": "1.11.19",
    "fastify": "5.6.2",
    "get-port": "7.1.0",
    "html-tags": "5.1.0",
    "iconify-icon": "3.0.2",
    "isbot": "5.1.32",
    "lodash": "4.17.21",
    "pino-http": "11.0.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "7.68.0",
    "react-router": "7.10.1",
    "uuid": "13.0.0",
    "zod": "4.1.13",
    "zustand": "5.0.9",
    "zustand-x": "6.2.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@react-router/dev": "7.10.1",
    "@redux-devtools/extension": "3.3.0",
    "@tanstack/eslint-plugin-query": "5.91.2",
    "@tanstack/react-query-devtools": "5.91.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/lodash": "4.17.21",
    "@types/node": "25.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.49.0",
    "@typescript-eslint/utils": "8.49.0",
    "eslint": "9.39.1",
    "eslint-plugin-css-modules": "2.12.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "eslint-plugin-security": "3.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "16.5.0",
    "jiti": "2.6.1",
    "pino": "10.1.0",
    "pino-pretty": "13.1.3",
    "react-router-devtools": "6.0.0",
    "sass-embedded": "1.96.0",
    "type-fest": "5.3.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.49.0",
    "vite": "7.2.7",
    "vite-plugin-checker": "0.12.0",
    "vite-tsconfig-paths": "5.1.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
