# Claude Code settings (machine-specific)
/.claude/settings.local.json

# Environment files (may contain secrets)
.env.local*

# Local logs and tool output
/logs/

# Node dependencies (installed from lockfile)
/node_modules/

# TypeScript incremental build cache (project-references buildinfo and emit)
/.tsc-cache/

# VS Code settings (developer-specific)
/.vscode/settings.json
