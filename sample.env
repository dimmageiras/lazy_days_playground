# ==============================================================================
# SERVER SETTINGS
# ==============================================================================

# Logging level for the application
# Options: debug, error, fatal, info, silent, trace, warn
# Default: info
LOG_LEVEL=info

# Host IP address (use 0.0.0.0 to listen on all interfaces)
VITE_APP_HOST=0.0.0.0

# Port where the application will run
VITE_APP_PORT=5173

# ==============================================================================
# GEL DATABASE
# ==============================================================================

# Admin password for the gel_db container. Single source of truth:
# docker-compose.yaml maps it into the container as GEL_SERVER_PASSWORD,
# and the gel CLI / client SDK auto-read GEL_PASSWORD on the host side.
GEL_PASSWORD=your-password

# Connection components — auto-read by the gel CLI and client SDK.
# Using individual variables (instead of a combined GEL_DSN) avoids
# duplicating the password.
GEL_HOST=localhost
GEL_PORT=5656
GEL_BRANCH=main

# Client-side TLS verification mode (how the CLI/SDK validate the server cert).
# Options: strict, no_host_verification, insecure
# Use "insecure" for local dev so the client accepts the self-signed cert
# generated by the server in insecure_dev_mode.
GEL_CLIENT_TLS_SECURITY=insecure

# Security mode the gel_db container enforces for incoming connections.
# Options: strict, insecure_dev_mode
# "insecure_dev_mode" is for local dev only: it disables strict TLS,
# accepts plaintext on the binary protocol port, and disables password
# auth from loopback. Never use in production — pair with a real cert
# and "strict" instead.
GEL_SERVER_SECURITY=insecure_dev_mode

# ==============================================================================
# AUTHENTICATION & ENCRYPTION
# ==============================================================================

# Secrets for signing and encryption
# ⚠️ MUST be at least 32 characters (recommended: 88 chars from base64 64 bytes)
# ⚠️ Use a cryptographically random string in production
# Generate with: openssl rand -base64 64
COOKIE_SECRET=generate-new-secret-here
JWT_SECRET=generate-new-secret-here

# Encryption algorithm for auth tokens
# Options: aes-128-gcm, aes-192-gcm, aes-256-gcm
# Recommended: aes-256-gcm (NIST-approved, hardware-accelerated)
TOKEN_ENCRYPTION_METHOD=aes-256-gcm

# Advanced encryption parameters (⚠️ Only modify if you know what you're doing)
# SALT_LENGTH: Bytes for key derivation salt (16 = 128-bit security)
SALT_LENGTH=16

# IV_LENGTH: Bytes for initialization vector (16 = AES-GCM standard)
IV_LENGTH=16

# AUTH_TAG_LENGTH: Bytes for GCM authentication tag (16 = 128-bit integrity)
AUTH_TAG_LENGTH=16

# KEY_LENGTH: Bytes for encryption key (32 = 256-bit AES)
KEY_LENGTH=32

# ==============================================================================
# EMAIL (Resend)
# ==============================================================================

# Resend API key for sending transactional email
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=paste-your-resend-api-key-here

# Resend "from" address (e.g. onboarding@resend.dev for sandbox, or your verified domain)
RESEND_FROM_EMAIL=onboarding@resend.dev

# ==============================================================================
# DEVELOPMENT SETTINGS (Development only, optional)
# ==============================================================================

# Enable development mode (true/false). Optional; default inferred.
VITE_APP_IS_DEVELOPMENT=true

# ==============================================================================
# DEV TOOLS (Development only, optional)
# ==============================================================================

# Enable all dev tools (true/false)
VITE_APP_ALL_DEV_TOOLS=true

# Enable React Query DevTools (true/false)
VITE_APP_RQDT=true

# Enable React Router DevTools (true/false)
VITE_APP_RRDT=true
